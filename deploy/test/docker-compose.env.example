# Copy this file to `.env` in the deployment package root before running
# `docker compose up -d --build`.

POSTGRES_USER=crm_test_user
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=crm_test_db

APP_ENV=test
FRONTEND_PUBLIC_URL=https://crm-test.example.com
BACKEND_PUBLIC_URL=https://crm-test.example.com
ALLOWED_ORIGINS=https://crm-test.example.com

JWT_SECRET_KEY=replace_me_with_a_strong_secret
FEISHU_APP_ID=replace_me
FEISHU_APP_SECRET=replace_me
FEISHU_REDIRECT_URI=

DISPATCH_WEBHOOK_SECRET=replace_me
DISPATCH_API_URL=https://dispatch-test.example.com

NGINX_SERVER_NAME=crm-test.example.com
