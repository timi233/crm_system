# Dispatch System Integration Configuration

# Webhook secret for HMAC-SHA256 signature verification
# Generate a secure random string for production
DISPATCH_WEBHOOK_SECRET=your_webhook_secret_here

# Dispatch system API endpoint
DISPATCH_API_URL=http://localhost:3000

# Example for production:
# DISPATCH_API_URL=https://dispatch.yourcompany.com
# DISPATCH_WEBHOOK_SECRET=use_a_strong_random_secret_at_least_32_chars