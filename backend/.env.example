# Application Environment
APP_ENV=development

# Public URLs - required for external integrations that lack request context
# These are NOT used for frontend API calls (frontend uses relative /api path)
# FRONTEND_PUBLIC_URL: used for Feishu redirect_uri construction, background tasks, external links
# BACKEND_PUBLIC_URL: used for webhook callbacks, external integrations
FRONTEND_PUBLIC_URL=http://localhost:3002
BACKEND_PUBLIC_URL=http://localhost:8000

# CORS Origins - fallback for cross-origin requests when same-origin proxy is not used
# Production recommendation: use same-origin reverse proxy (nginx) instead of CORS
# Do NOT use "*" with credentials - must specify explicit origins
ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Database
DATABASE_URL=postgresql+asyncpg://crm_user:change_me@localhost:5432/crm_db

# Authentication
JWT_SECRET_KEY=change_me

# Product installation credential encryption
# Required in production. Use a strong random value with at least 32 chars.
PRODUCT_INSTALLATION_CREDENTIAL_KEY=change_me_to_a_random_32_char_minimum_key

# Feishu Integration - redirect_uri must be explicitly configured for OAuth whitelist
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
FEISHU_WS_ENABLED=false

# Dispatch Integration
DISPATCH_WEBHOOK_SECRET=
DISPATCH_API_URL=http://localhost:3000
